#!/bin/sh
# 1. Branch guard: never commit directly to main/master.
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
case "$branch" in
  main|master)
    echo "" >&2
    echo "  BLOCKED: direct commits to '$branch' are not allowed." >&2
    echo "  Create a working branch first:  git switch -c feature/your-change" >&2
    echo "  Branch types: feature/  fix/  refactor/  docs/  chore/" >&2
    echo "" >&2
    exit 1 ;;
esac
# 2. Keep the docs digest in sync, staged into THIS commit (idempotent, no dangling file).
root=$(git rev-parse --show-toplevel)
if [ -f "$root/tools/digest.py" ]; then
  python3 "$root/tools/digest.py" >/dev/null 2>&1 && git add "$root/docs/_digest/index.md" 2>/dev/null
fi
exit 0
